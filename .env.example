VITE_GOOGLE_MAPS_API_KEY=your_google_maps_api_key_here

# OpenRouter AI Configuration
# Pattern: OpenAI SDK + OpenRouter base URL
Nemotron_API=sk-or-v1-your_openrouter_api_key_here

# Optional: Override model (default: nvidia/nemotron-3-super-120b-a12b:free)
# VITE_OPENROUTER_MODEL=openai/gpt-4o

# Optional: Override base URL (default: https://openrouter.ai/api/v1)
# VITE_OPENROUTER_BASE_URL=https://openrouter.ai/api/v1